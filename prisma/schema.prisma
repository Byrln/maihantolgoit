generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String?
  name         String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Media {
  id             String          @id @default(cuid())
  alt            String
  url            String
  width          Int?
  height         Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accommodations Accommodation[]
  pagesHero      Page[]          @relation("PageHero")
  postsCover     Post[]          @relation("PostCover")
  services       Service[]
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String?  @db.Text
  body        Json?
  sections    Json?
  heroImageId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  heroImage   Media?   @relation("PageHero", fields: [heroImageId], references: [id])

  @@index([heroImageId], map: "Page_heroImageId_fkey")
}

model NavLink {
  id        String   @id @default(cuid())
  label     String
  href      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String    @id @default(cuid())
  title       String
  slug        String?   @unique
  excerpt     String?   @db.Text
  body        Json?
  imageId     String?
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  image       Media?    @relation(fields: [imageId], references: [id])

  @@index([imageId], map: "Service_imageId_fkey")
}

model Accommodation {
  id        String   @id @default(cuid())
  title     String
  summary   String   @db.Text
  details   Json?
  imageId   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     Media?   @relation(fields: [imageId], references: [id])

  @@index([imageId], map: "Accommodation_imageId_fkey")
}

model Post {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  category     String?
  excerpt      String    @db.Text
  body         Json?
  coverImageId String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  coverImage   Media?    @relation("PostCover", fields: [coverImageId], references: [id])

  @@index([coverImageId], map: "Post_coverImageId_fkey")
}

enum Role {
  ADMIN
  USER
}
